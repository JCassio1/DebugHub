{
  "name": "debughub",
  "displayName": "DebugHub",
  "version": "1.1.0",
  "publisher": "JoselsonDias",
  "license": "MIT",
  "icon": "media/debughub-logo.png",
  "description": "Manage all your VS Code debug configurations in one place. Start, stop, and monitor multiple debuggers simultaneously — built for monorepos.",
  "keywords": [
    "debug",
    "monorepo",
    "debugger",
    "launch",
    "multi-debug"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/debughub.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debughub.openPopover",
        "title": "DebugHub: Open Debug Panel"
      },
      {
        "command": "debughub.startAllDebugConfigurations",
        "title": "DebugHub: Start All Debuggers"
      },
      {
        "command": "debughub.startDebugConfiguration",
        "title": "DebugHub: Start Debug Configuration"
      },
      {
        "command": "debughub.stopDebugSession",
        "title": "DebugHub: Stop Debug Session"
      },
      {
        "command": "debughub.refreshSidebar",
        "title": "DebugHub: Refresh"
      },
      {
        "command": "debughub.startSelectedDebugConfigurations",
        "title": "DebugHub: Start Selected Debuggers",
        "icon": "$(play)"
      },
      {
        "command": "debughub.startDebugGroup",
        "title": "DebugHub: Start Debug Group",
        "icon": "$(play)"
      },
      {
        "command": "debughub.stopDebugGroup",
        "title": "DebugHub: Stop Debug Group",
        "icon": "$(primitive-square)"
      },
      {
        "command": "debughub.assignDebugGroup",
        "title": "DebugHub: Assign Debug Group",
        "icon": "$(folder)"
      },
      {
        "command": "debughub.stopAllDebugSessions",
        "title": "DebugHub: Stop All Debuggers",
        "icon": "$(debug-stop)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
